---
import WorkCard from './work/WorkCard.astro';
import WorkModal from './work/WorkModal.astro';
import WorkPagination from './work/WorkPagination.astro';
import type { GitHubRepo, ProjectData } from '../types/portfolio';

let projects: ProjectData[] = [];
try {
  const headers: Record<string, string> = {
    'User-Agent': 'talhus-portfolio'
  };

  const token = import.meta.env.GITHUB_TOKEN;
  if (token) {
    headers['Authorization'] = `token ${token}`;
  }

  const res = await fetch('https://api.github.com/users/talhus/repos?per_page=100&sort=updated', { headers });
  if (res.ok) {
    const repos: GitHubRepo[] = await res.json();
    if (Array.isArray(repos)) {
      const filtered = repos.filter((repo) => repo.topics && repo.topics.includes('portfolio'));
      
      const sorted = filtered.sort((a, b) => {
        return new Date(b.pushed_at || b.updated_at || 0).getTime() - new Date(a.pushed_at || a.updated_at || 0).getTime();
      });

      projects = sorted.map((project) => {
        const techTags = getProjectTechTags(project);
        const colorClass = getTechColorClass(techTags);
        const desc = project.description || `${techTags.join(' / ')} project built by Talha Bay.`;

        return {
          name: project.name,
          description: desc,
          techTags: techTags,
          homepage: project.homepage,
          html_url: project.html_url,
          colorClass: colorClass
        };
      });
    }
  } else {
    console.error(`GitHub API responded with status ${res.status}`);
  }
} catch (e) {
  console.error('Error fetching repositories from GitHub:', e);
}

function getProjectTechTags(project: GitHubRepo): string[] {
  const tagsSet = new Set<string>();
  const topics = (project.topics || []).map((t: string) => t.toLowerCase());
  const lang = (project.language || '').toLowerCase();
  const desc = (project.description || '').toLowerCase();

  if (topics.includes('golang') || lang === 'go' || desc.includes('built with go') || desc.includes('golang')) {
    tagsSet.add('Go');
  }
  if (lang === 'typescript' || topics.includes('typescript') || topics.includes('ts')) {
    tagsSet.add('TypeScript');
  }
  if (lang === 'javascript' || topics.includes('javascript') || topics.includes('js') || desc.includes('react')) {
    tagsSet.add('JavaScript');
  }
  if (topics.includes('react') || desc.includes('react')) {
    tagsSet.add('React');
  }
  if (lang === 'astro' || topics.includes('astro')) {
    tagsSet.add('Astro');
  }
  if (topics.includes('redux')) {
    tagsSet.add('Redux');
  }
  if (topics.includes('docker') || desc.includes('docker')) {
    tagsSet.add('Docker');
  }

  topics.forEach((t: string) => {
    if (t !== 'portfolio' && t !== 'golang' && t !== 'javascript' && t !== 'typescript' && t !== 'react' && t !== 'astro' && t !== 'redux' && t !== 'docker') {
      tagsSet.add(t.charAt(0).toUpperCase() + t.slice(1));
    }
  });

  if (tagsSet.size === 0 && project.language) {
    tagsSet.add(project.language);
  }

  return Array.from(tagsSet);
}

function getTechColorClass(techTags: string[]): string {
  const lower = techTags.map(t => t.toLowerCase());
  if (lower.includes('go')) return 'bg-cyan';
  if (lower.includes('typescript') || lower.includes('react')) return 'bg-blue';
  if (lower.includes('astro')) return 'bg-purple';
  if (lower.includes('javascript')) return 'bg-amber';
  return 'bg-default';
}
---

<section id="work" class="section">
  <div class="section-header">
    <h2>Selected Work</h2>
  </div>
  
  <div class="project-grid" id="project-grid">
    {projects.map((project) => (
      <WorkCard project={project} />
    ))}
  </div>

  {projects.length > 3 && <WorkPagination />}

  <WorkModal />
</section>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    min-height: 480px;
    align-content: start;
  }

  @media (max-width: 1024px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = Array.from(document.querySelectorAll('.project-card')) as HTMLElement[];
    const modal = document.getElementById('project-modal');
    
    if (modal) {
      document.body.appendChild(modal);
    }

    const closeBtn = document.getElementById('close-modal');
    const mTitle = document.getElementById('modal-title');
    const mDesc = document.getElementById('modal-description');
    const mTags = document.getElementById('modal-tags');
    const mImgContainer = document.getElementById('modal-image-container');
    const mDemo = document.getElementById('modal-demo');
    const mGithub = document.getElementById('modal-github');

    // Modal interaction
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('.project-links')) return;
        
        const rawData = card.getAttribute('data-project');
        if (!rawData) return;
        
        const project = JSON.parse(rawData);
        
        if (mTitle) mTitle.textContent = project.name;
        if (mDesc) mDesc.textContent = project.description;
        
        if (mTags) {
          mTags.innerHTML = (project.techTags || [])
            .map((t: string) => `<span class="tag ${t === 'Go' || t === 'JavaScript' || t === 'TypeScript' || t === 'React' ? 'tag-lang' : ''}">${t}</span>`)
            .join('');
        }
        
        if (mImgContainer) {
          mImgContainer.innerHTML = '';
          mImgContainer.className = `modal-image ${project.colorClass}`;
        }

        if (mDemo) {
          if (project.homepage) {
            mDemo.setAttribute('href', project.homepage);
            mDemo.classList.remove('hidden');
          } else {
            mDemo.classList.add('hidden');
          }
        }
        
        if (mGithub && project.html_url) {
          mGithub.setAttribute('href', project.html_url);
        }
        
        if (modal) {
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    const closeModal = () => {
      if (modal) {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      }
    };

    if (closeBtn) closeBtn.addEventListener('click', closeModal);

    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeModal();
        }
      });
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });

    // Pagination Logic
    const ITEMS_PER_PAGE = 3;
    const totalProjects = cards.length;
    
    if (totalProjects > ITEMS_PER_PAGE) {
      const prevBtn = document.getElementById('prev-page') as HTMLButtonElement | null;
      const nextBtn = document.getElementById('next-page') as HTMLButtonElement | null;
      const pageNumbersContainer = document.getElementById('page-numbers');
      const totalPages = Math.ceil(totalProjects / ITEMS_PER_PAGE);
      let currentPage = 1;

      const renderPaginationButtons = () => {
        if (!pageNumbersContainer) return;
        pageNumbersContainer.innerHTML = '';

        for (let i = 1; i <= totalPages; i++) {
          const btn = document.createElement('button');
          btn.className = `num-btn ${i === currentPage ? 'active' : ''}`;
          btn.textContent = String(i).padStart(2, '0');
          btn.setAttribute('aria-label', `Page ${i}`);
          btn.addEventListener('click', () => goToPage(i));
          pageNumbersContainer.appendChild(btn);
        }
      };

      let isInitialLoad = true;

      const goToPage = (page: number) => {
        currentPage = page;
        const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
        const endIndex = startIndex + ITEMS_PER_PAGE;

        cards.forEach((card, index) => {
          if (index >= startIndex && index < endIndex) {
            card.style.display = 'flex';
          } else {
            card.style.display = 'none';
          }
        });

        if (prevBtn) prevBtn.disabled = currentPage === 1;
        if (nextBtn) nextBtn.disabled = currentPage === totalPages;

        renderPaginationButtons();

        if (!isInitialLoad) {
          const workSection = document.getElementById('work');
          if (workSection) {
            workSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
        isInitialLoad = false;
      };

      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          if (currentPage > 1) goToPage(currentPage - 1);
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          if (currentPage < totalPages) goToPage(currentPage + 1);
        });
      }

      // Initialize first page
      goToPage(1);
    }
  });
</script>
---
const githubIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>`;
const externalIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>`;
---

<div id="project-modal" class="modal-overlay hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal-content">
    <button id="close-modal" class="close-btn" aria-label="Close modal">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    <div id="modal-image-container" class="modal-image"></div>
    <div class="modal-body">
      <h3 id="modal-title">Project Title</h3>
      <p id="modal-description">Project Description</p>
      <div id="modal-tags" class="project-tags modal-tags"></div>
      <div class="modal-links project-links">
        <a id="modal-demo" href="#" target="_blank" rel="noopener noreferrer" class="btn-link hidden">
          <span class="icon" set:html={externalIcon} /> Live Demo
        </a>
        <a id="modal-github" href="#" target="_blank" rel="noopener noreferrer" class="btn-link">
          <span class="icon" set:html={githubIcon} /> GitHub
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 1000;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1.5rem;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .modal-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .modal-content {
    background: #141414;
    width: 100%;
    max-width: 680px;
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    flex-direction: column;
    max-height: 85vh;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.9);
  }

  .close-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #ffffff;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: all 0.2s ease;
  }

  .close-btn svg {
    width: 18px;
    height: 18px;
  }

  .close-btn:hover {
    background: rgba(0, 0, 0, 0.85);
    transform: scale(1.08);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .modal-image {
    width: 100%;
    height: 130px;
    position: relative;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* Gradient Header Banners */
  :global(.modal-image.bg-cyan) { background: linear-gradient(135deg, #00455e, #00ADD8); }
  :global(.modal-image.bg-blue) { background: linear-gradient(135deg, #123356, #3178C6); }
  :global(.modal-image.bg-yellow) { background: linear-gradient(135deg, #665300, #FFD43B); }
  :global(.modal-image.bg-purple) { background: linear-gradient(135deg, #37146e, #8b5cf6); }
  :global(.modal-image.bg-amber) { background: linear-gradient(135deg, #5c2b00, #f59e0b); }
  :global(.modal-image.bg-default) { background: linear-gradient(135deg, #222, #444); }

  .modal-body {
    padding: 1.75rem 2rem 2rem;
    overflow-y: auto;
  }

  .modal-body h3 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text-main);
  }

  .modal-body p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    line-height: 1.6;
    font-size: 1rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .modal-tags {
    margin-top: 1rem;
    margin-bottom: 1.5rem;
  }

  :global(.modal-tags .tag) {
    background: rgba(255, 255, 255, 0.08);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  :global(.modal-tags .tag-lang) {
    background: rgba(255, 255, 255, 0.18);
    color: var(--text-main);
    font-weight: 600;
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .btn-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.1rem;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s ease;
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--text-main);
  }

  .btn-link:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .icon {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon :global(svg) {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .hidden { display: none !important; }
</style>

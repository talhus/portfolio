---
---

<section id="hero" class="hero">
  <div class="hero-canvas-container">
    <canvas id="hero-canvas"></canvas>
  </div>
  <div class="hero-content">
    <h1 class="hero-title">Building things <br> that actually work.</h1>
    <a href="#work" class="btn-primary">View Work</a>
  </div>
</section>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const container = document.querySelector('.hero-canvas-container');

  if (canvas && container) {
    const scene = new THREE.Scene();
    
    // Fallback to viewport bounds if client dimensions are not calculated yet on mount
    let width = container.clientWidth || window.innerWidth;
    let height = container.clientHeight || (window.innerHeight * 0.9);
    
    const camera = new THREE.PerspectiveCamera(75, width / height, 0.1, 1000);
    camera.position.z = 5;

    const renderer = new THREE.WebGLRenderer({
      canvas: canvas,
      alpha: true,
      antialias: true
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(width, height);

    // Create central morphing sphere
    const particleCount = 900;
    const geometry = new THREE.BufferGeometry();
    const positions = new Float32Array(particleCount * 3);
    const originalPositions = new Float32Array(particleCount * 3);
    const randomOffsets = new Float32Array(particleCount);

    for (let i = 0; i < particleCount; i++) {
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos((Math.random() * 2) - 1);
      const radius = 1.8 + Math.random() * 0.15;

      const x = radius * Math.sin(phi) * Math.cos(theta);
      const y = radius * Math.sin(phi) * Math.sin(theta);
      const z = radius * Math.cos(phi);

      positions[i * 3] = x;
      positions[i * 3 + 1] = y;
      positions[i * 3 + 2] = z;

      originalPositions[i * 3] = x;
      originalPositions[i * 3 + 1] = y;
      originalPositions[i * 3 + 2] = z;

      randomOffsets[i] = Math.random() * Math.PI * 2;
    }

    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));

    // Create sparse outer shell
    const outerCount = 180;
    const outerGeometry = new THREE.BufferGeometry();
    const outerPositions = new Float32Array(outerCount * 3);

    for (let i = 0; i < outerCount; i++) {
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos((Math.random() * 2) - 1);
      const radius = 3.2 + Math.random() * 0.8;

      outerPositions[i * 3] = radius * Math.sin(phi) * Math.cos(theta);
      outerPositions[i * 3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
      outerPositions[i * 3 + 2] = radius * Math.cos(phi);
    }

    outerGeometry.setAttribute('position', new THREE.BufferAttribute(outerPositions, 3));

    // High quality circle particle texture helper
    function createCircleTexture(opacity = 1) {
      const textureCanvas = document.createElement('canvas');
      textureCanvas.width = 32;
      textureCanvas.height = 32;
      const ctx = textureCanvas.getContext('2d');
      if (ctx) {
        const gradient = ctx.createRadialGradient(16, 16, 0, 16, 16, 16);
        gradient.addColorStop(0, `rgba(250, 250, 250, ${opacity})`);
        gradient.addColorStop(0.2, `rgba(250, 250, 250, ${opacity * 0.75})`);
        gradient.addColorStop(0.5, `rgba(250, 250, 250, ${opacity * 0.15})`);
        gradient.addColorStop(1, 'rgba(250, 250, 250, 0)');
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, 32, 32);
      }
      return new THREE.CanvasTexture(textureCanvas);
    }

    const innerMaterial = new THREE.PointsMaterial({
      size: 0.08,
      map: createCircleTexture(0.95),
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false
    });

    const outerMaterial = new THREE.PointsMaterial({
      size: 0.06,
      map: createCircleTexture(0.35),
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false
    });

    const innerPoints: THREE.Points = new THREE.Points(geometry, innerMaterial);
    const outerPoints: THREE.Points = new THREE.Points(outerGeometry, outerMaterial);

    scene.add(innerPoints);
    scene.add(outerPoints);

    // Responsive position setup
    function updatePositionsForDevice() {
      if (window.innerWidth > 768) {
        innerPoints.position.x = 1.6;
        outerPoints.position.x = 1.6;
        innerPoints.position.y = 0;
        outerPoints.position.y = 0;
      } else {
        innerPoints.position.x = 0;
        outerPoints.position.x = 0;
        innerPoints.position.y = -0.6;
        outerPoints.position.y = -0.6;
      }
    }
    updatePositionsForDevice();

    // Mouse interactive movement variables
    let mouseX = 0, mouseY = 0;
    let targetX = 0, targetY = 0;

    window.addEventListener('mousemove', (e) => {
      targetX = (e.clientX / window.innerWidth) * 2 - 1;
      targetY = -(e.clientY / window.innerHeight) * 2 + 1;
    });

    const clock = new THREE.Clock();

    function animate() {
      requestAnimationFrame(animate);

      const elapsedTime = clock.getElapsedTime();

      // Smooth mouse follow interpolation
      mouseX += (targetX - mouseX) * 0.05;
      mouseY += (targetY - mouseY) * 0.05;

      // Base rotations (minimal and slow)
      innerPoints.rotation.y = elapsedTime * 0.025;
      innerPoints.rotation.x = elapsedTime * 0.012;

      outerPoints.rotation.y = -elapsedTime * 0.008;
      outerPoints.rotation.x = -elapsedTime * 0.004;

      // Apply parallax displacement based on mouse movement
      const basePosX = window.innerWidth > 768 ? 1.6 : 0;
      const basePosY = window.innerWidth > 768 ? 0 : -0.6;

      innerPoints.position.x += (basePosX + mouseX * 0.25 - innerPoints.position.x) * 0.05;
      innerPoints.position.y += (basePosY + mouseY * 0.25 - innerPoints.position.y) * 0.05;

      outerPoints.position.x += (basePosX + mouseX * 0.45 - outerPoints.position.x) * 0.05;
      outerPoints.position.y += (basePosY + mouseY * 0.45 - outerPoints.position.y) * 0.05;

      // Gentle organic breathing / morphing effect on the sphere
      const posAttr = geometry.attributes.position;
      for (let i = 0; i < particleCount; i++) {
        const x = originalPositions[i * 3];
        const y = originalPositions[i * 3 + 1];
        const z = originalPositions[i * 3 + 2];

        const len = Math.sqrt(x * x + y * y + z * z);
        
        // Create an organic wave using trigonometric patterns & random offsets
        const offset = 
          Math.sin(x * 1.5 + elapsedTime * 0.4 + randomOffsets[i]) * 
          Math.cos(y * 1.5 + elapsedTime * 0.4) * 0.12;
        
        const scale = (len + offset) / len;

        posAttr.setXYZ(i, x * scale, y * scale, z * scale);
      }
      posAttr.needsUpdate = true;

      renderer.render(scene, camera);
    }
    animate();

    // Use ResizeObserver to ensure the canvas matches the container's bounds perfectly
    const resizeObserver = new ResizeObserver((entries) => {
      for (const entry of entries) {
        const w = entry.contentRect.width || container.clientWidth || window.innerWidth;
        const h = entry.contentRect.height || container.clientHeight || (window.innerHeight * 0.9);

        camera.aspect = w / h;
        camera.updateProjectionMatrix();

        renderer.setSize(w, h);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        updatePositionsForDevice();
      }
    });
    resizeObserver.observe(container);
  }
</script>
